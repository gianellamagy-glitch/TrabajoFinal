
 lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitud de Producción</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0d1117;
      color: white;
      margin: 0;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 30px;
    }

    h1 {
      text-align: center;
      margin-bottom: 30px;
    }

    .card {
      background: #161b22;
      padding: 20px;
      border-radius: 15px;
      margin-bottom: 20px;
      border: 1px solid #30363d;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-bottom: 10px;
      border-radius: 8px;
      border: none;
    }

    button {
      width: 100%;
      padding: 10px;
      background: #1f6feb;
      border: none;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }

    pre {
      background: #0d1117;
      padding: 10px;
      border-radius: 10px;
      overflow-x: auto;
    }
  </style>
</head>

<body>

<div class="container">
  <h1>Solicitud de Orden de Producción</h1>

  <div class="card">
    <h2>Formulario</h2>
    <input placeholder="Código">
    <input placeholder="Producto">
    <input type="number" placeholder="Cantidad">
    <input type="date">
    <input placeholder="Responsable">
    <button>Enviar</button>
  </div>

  <div class="card">
    <h2>Gramática</h2>
    <pre>
S -> Orden
Orden -> encabezado cuerpo
encabezado -> ORDEN id fecha
cuerpo -> producto cantidad responsable
producto -> PROD nombre
cantidad -> CANT num
responsable -> RESP nombre
    </pre>
  </div>

  <div class="card">
    <h2>Derivación Izquierda</h2>
    <pre>
S
=> Orden
=> encabezado cuerpo
=> ORDEN id fecha cuerpo
=> ORDEN id fecha PROD nombre CANT num RESP nombre
    </pre>
  </div>

  <div class="card">
    <h2>Derivación Derecha</h2>
    <pre>
S
=> Orden
=> encabezado cuerpo
=> encabezado producto cantidad responsable
=> ORDEN id fecha PROD nombre CANT num RESP nombre
    </pre>
  </div>

  <div class="card">
    <h2>Árbol</h2>
    <pre>
        S
        |
      Orden
     /     \
 encabezado  cuerpo
    </pre>
  </div>

</div>

</body>
</html>

